{
	"name": "@kheopskit/react",
	"version": "5.0.1",
	"description": "",
	"private": false,
	"sideEffects": false,
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"test": "vitest run --root=../.. packages/react",
		"dev": "tsup --watch",
		"build": "tsup",
		"prepack": "tsup",
		"clean": "rm -rf ./dist && rm -rf ./node_modules",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [],
	"author": "Kheops (https://github.com/0xKheops)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kheopskit/kheopskit.git"
	},
	"license": "ISC",
	"peerDependencies": {
		"@kheopskit/core": "^5.0.1",
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"rxjs": ">=7.0.0"
	},
	"devDependencies": {
		"@kheopskit/core": "workspace:*",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rxjs": "^7.8.2"
	},
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"tsconfig": "tsconfig.build.json",
		"splitting": false,
		"sourcemap": true,
		"clean": true,
		"dts": true,
		"format": [
			"esm",
			"cjs"
		],
		"target": "es2020",
		"banner": {
			"js": "\"use client\";"
		}
	}
}
