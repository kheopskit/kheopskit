{
	"name": "@kheopskit/core",
	"version": "1.0.1",
	"description": "",
	"private": false,
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./polkadot": {
			"types": "./dist/polkadot.d.ts",
			"import": "./dist/polkadot.mjs",
			"require": "./dist/polkadot.js"
		},
		"./ethereum": {
			"types": "./dist/ethereum.d.ts",
			"import": "./dist/ethereum.mjs",
			"require": "./dist/ethereum.js"
		},
		"./solana": {
			"types": "./dist/solana.d.ts",
			"import": "./dist/solana.mjs",
			"require": "./dist/solana.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"test": "vitest run --root=../.. packages/core",
		"dev": "tsup --watch",
		"build": "tsup",
		"prepack": "tsup",
		"clean": "rm -rf ./dist && rm -rf ./node_modules",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [],
	"author": "Kheops (https://github.com/0xKheops)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kheopskit/kheopskit.git"
	},
	"license": "ISC",
	"peerDependencies": {
		"@reown/appkit": ">=1.7.0",
		"@solana/kit": ">=6.0.0",
		"@wallet-standard/app": ">=1.1.0",
		"@wallet-standard/base": ">=1.1.0",
		"mipd": ">=0.0.7",
		"polkadot-api": ">=2.0.0",
		"rxjs": ">=7.8.0",
		"viem": ">=2.0.0"
	},
	"peerDependenciesMeta": {
		"@reown/appkit": {
			"optional": true
		},
		"@solana/kit": {
			"optional": true
		},
		"@wallet-standard/app": {
			"optional": true
		},
		"@wallet-standard/base": {
			"optional": true
		},
		"mipd": {
			"optional": true
		},
		"polkadot-api": {
			"optional": true
		},
		"viem": {
			"optional": true
		}
	},
	"dependencies": {
		"@noble/hashes": "^1.8.0",
		"@scure/base": "^1.2.6",
		"lodash-es": "^4.18.1"
	},
	"devDependencies": {
		"@reown/appkit": "^1.8.20",
		"@solana/kit": "^6.9.0",
		"@solana/wallet-standard-features": "^1.3.0",
		"@types/lodash-es": "^4.17.12",
		"@wallet-standard/app": "^1.1.1",
		"@wallet-standard/base": "^1.1.1",
		"@wallet-standard/features": "^1.1.1",
		"mipd": "^0.0.7",
		"polkadot-api": "^2.1.6",
		"rxjs": "^7.8.2",
		"viem": "^2.52.2"
	},
	"tsup": {
		"entry": [
			"src/index.ts",
			"src/polkadot.ts",
			"src/ethereum.ts",
			"src/solana.ts"
		],
		"tsconfig": "tsconfig.build.json",
		"splitting": true,
		"sourcemap": true,
		"clean": true,
		"dts": true,
		"format": [
			"esm",
			"cjs"
		],
		"target": "es2020"
	}
}
