{
	"name": "kheopskit",
	"version": "0.2.2",
	"private": true,
	"description": "",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"dev:vite": "pnpm --filter vite-react dev",
		"dev:tanstack": "pnpm --filter tanstack-start dev",
		"dev:next": "pnpm --filter nextjs-react dev",
		"build": "pnpm build:packages && pnpm --filter vite-react build",
		"build:packages": "pnpm -F @kheopskit/core -F @kheopskit/react build",
		"build:examples": "pnpm -F vite-react -F nextjs-react -F tanstack-start build",
		"test:e2e": "pnpm build:packages && pnpm build:examples && playwright test -c e2e",
		"test:e2e:run": "playwright test -c e2e",
		"format": "pnpm biome format --write .",
		"postinstall": "pnpm papi",
		"clean": "pnpm -F @kheopskit/core -F @kheopskit/react -F vite-react clean && rm -rf ./.papi/descriptors/dist && rm -rf node_modules",
		"bump": "pnpm changeset version",
		"publish": "pnpm publish -r --no-git-checks --access public --tag latest",
		"sync-peer-deps": "node scripts/sync-peer-deps.mjs",
		"changeset-release-pr": "changeset version && pnpm sync-peer-deps && pnpm install && pnpm build:packages",
		"check": "pnpm biome check .",
		"typecheck": "pnpm -r --parallel typecheck",
		"knip": "knip"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.60.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"happy-dom": "^20.10.2",
		"jsdom": "^29.1.1",
		"knip": "^6.16.1",
		"simple-git-hooks": "^2.13.1",
		"tsup": "^8.5.1",
		"typescript": "~6.0.3",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@kheopskit/core": "workspace:*",
		"@kheopskit/react": "workspace:*",
		"@polkadot-api/descriptors": "file:.papi/descriptors",
		"polkadot-api": "^2.1.6"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm biome check --staged --error-on-warnings --no-errors-on-unmatched"
	}
}
