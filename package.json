{
	"name": "kheopskit",
	"version": "0.2.0",
	"private": true,
	"description": "",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"dev:vite": "pnpm --filter vite-react dev",
		"dev:tanstack": "pnpm --filter tanstack-start dev",
		"dev:next": "pnpm --filter nextjs-react dev",
		"build": "pnpm build:packages && pnpm --filter vite-react build",
		"build:packages": "pnpm -F @kheopskit/core -F @kheopskit/react build",
		"format": "pnpm biome format --write .",
		"postinstall": "pnpm papi",
		"clean": "pnpm -F @kheopskit/core -F @kheopskit/react -F vite-react clean && rm -rf ./.papi/descriptors/dist && rm -rf node_modules",
		"bump": "pnpm changeset version",
		"publish": "pnpm publish -r --no-git-checks --access public --tag latest",
		"sync-peer-deps": "node scripts/sync-peer-deps.mjs",
		"changeset-release-pr": "changeset version && pnpm sync-peer-deps && pnpm install && pnpm build:packages",
		"check": "pnpm biome check .",
		"typecheck": "pnpm -r --parallel typecheck",
		"knip": "knip"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"happy-dom": "^20.9.0",
		"jsdom": "^29.1.1",
		"knip": "^6.11.0",
		"simple-git-hooks": "^2.13.1",
		"tsup": "^8.5.1",
		"typescript": "~6.0.3",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@kheopskit/core": "workspace:*",
		"@kheopskit/react": "workspace:*",
		"@polkadot-api/descriptors": "file:.papi/descriptors",
		"polkadot-api": "^2.1.2"
	},
	"simple-git-hooks": {
		"pre-commit": ".githooks/pre-commit.sh"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"simple-git-hooks"
		],
		"overrides": {
			"@kheopskit/core": "link:packages/core",
			"@kheopskit/react": "link:packages/react",
			"axios@>=1.0.0 <1.15.2": "^1.15.2",
			"postcss@<8.5.10": "^8.5.10",
			"hono@<4.12.18": "^4.12.18"
		}
	}
}
