{
	"$schema": "./node_modules/knip/schema.json",
	"ignoreDependencies": ["@kheopskit/core", "@kheopskit/react", "tslib"],
	"workspaces": {
		".": {
			"entry": [
				".papi/whitelist.ts",
				"e2e/playwright.config.ts",
				"e2e/tests/**/*.spec.ts"
			],
			"ignore": ["e2e/mocks/**"]
		},
		"packages/core": {
			"ignore": [
				"src/utils/sleep.ts",
				"src/utils/throwAfter.ts",
				"src/utils/storage.ts"
			]
		},
		"packages/react": {
			"ignoreDependencies": ["@types/react-dom", "react-dom"]
		},
		"examples/vite-react": {
			"entry": ["src/styles.css"],
			"ignore": [
				"src/components/ui/**",
				"src/lib/config/chains.ts",
				"src/lib/config/playgroundConfig.ts",
				"src/lib/getPolkadotApi.ts"
			],
			"ignoreBinaries": ["tailwindcss"]
		},
		"examples/nextjs-react": {
			"ignore": [
				"src/components/ui/**",
				"src/lib/config/chains.ts",
				"src/lib/config/playgroundConfig.ts",
				"src/lib/getPolkadotApi.ts"
			]
		},
		"examples/tanstack-start": {
			"ignore": [
				"src/components/ui/**",
				"src/lib/config/chains.ts",
				"src/lib/config/playgroundConfig.ts",
				"src/lib/getPolkadotApi.ts"
			]
		}
	}
}
